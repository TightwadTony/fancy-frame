<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Local network + Bonjour permissions required for mDNS discovery -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Photo Frame Remote needs access to your local network to discover and manage photo frames.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_photoframe._tcp</string>
    </array>
</dict>
</plist>
