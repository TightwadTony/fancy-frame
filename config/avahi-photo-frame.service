<?xml version="1.0" standalone='no'?>
<!DOCTYPE service-group SYSTEM "avahi-service.dtd">
<!--
  Advertises the Photo Frame management API via mDNS so iOS clients
  can discover it automatically using NWBrowser / Bonjour.
  Service type: _photoframe._tcp, port 8080.
-->
<service-group>
  <name replace-wildcards="yes">Photo Frame (%h)</name>
  <service>
    <type>_photoframe._tcp</type>
    <port>8080</port>
  </service>
</service-group>
